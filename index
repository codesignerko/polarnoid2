<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>폴라'노이드'</title>
    <style>
        @font-face {
            font-family: 'DungGeunMo';
            src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/noonfonts_six@1.2/DungGeunMo.woff') format('woff');
            font-weight: normal;
            font-style: normal;
        }

        :root {
            --mint-color: #B4D6C1;
            --bg-dark: #0a0a0a;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
            -webkit-user-select: none;
        }

        body {
            font-family: 'DungGeunMo', sans-serif;
            background-color: var(--mint-color);
            overflow: hidden;
            width: 100vw;
            height: 100vh;
        }

        .screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .screen.active {
            display: flex;
        }

        /* --- 시퀀스 1: 타이틀 화면 --- */
        #screen-title {
            background-color: var(--mint-color);
        }

        h1.title {
            font-size: 2.8rem;
            color: #2c3e35;
            margin-bottom: 25px;
            text-shadow: 2px 2px 0px #ffffff;
            letter-spacing: -1px;
        }

        .camera-svg-btn {
            width: 220px;
            height: 240px;
            cursor: pointer;
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.15));
            animation: float 3s ease-in-out infinite;
            transition: transform 0.15s ease;
        }

        .camera-svg-btn:active {
            transform: scale(0.92);
        }

        @keyframes float {
            0% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0); }
        }

        .instruction {
            margin-top: 30px;
            font-size: 1.1rem;
            color: #4a6355;
            animation: blink 1.5s infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* --- 시퀀스 2: 카메라 화면 --- */
        #screen-camera {
            background-color: var(--bg-dark);
        }

        #camera-stream {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 1;
            filter: url(#lens-distortion) contrast(1.05) brightness(1.02);
            transform: scale(1.08);
        }

        .viewfinder-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            z-index: 2;
            display: flex;
            justify-content: center;
            align-items: center;
            pointer-events: none;
        }

        .viewfinder-cutout {
            width: 230px;
            height: 230px;
            border-radius: 35px;
            box-shadow: 
                0 0 0 2000px #0a0a0a,
                inset 0 0 15px rgba(0, 0, 0, 0.9),
                inset 0 0 35px rgba(0, 0, 0, 0.7);
            position: relative;
            background: transparent;
            border: 4px solid #1a1a1a;
        }

        .viewfinder-cutout::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border-radius: 30px;
            box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.15);
            pointer-events: none;
        }

        .shutter-btn {
            position: absolute;
            bottom: 45px;
            z-index: 3;
            width: 75px;
            height: 75px;
            border-radius: 50%;
            background-color: #ffffff;
            border: 4px solid #dcdcdc;
            outline: 5px solid rgba(255, 255, 255, 0.8);
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.6);
        }

        .shutter-btn:active {
            background-color: #e0e0e0;
            transform: scale(0.92);
        }

        /* --- 시퀀스 3, 4: 현상 화면 --- */
        #screen-develop {
            background-color: var(--mint-color);
            z-index: 10;
        }

        .polaroid-frame {
            background-color: #ffffff;
            padding: 16px 16px 65px 16px;
            box-shadow: 0 12px 25px rgba(0,0,0,0.25);
            position: relative;
            transform: translateY(100vh);
            transition: transform 1.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border-radius: 4px;
        }

        .polaroid-frame.slide-up {
            transform: translateY(-15px);
        }

        .photo-area {
            width: 250px;
            height: 330px;
            background-color: #ffffff;
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 0 8px rgba(0,0,0,0.1);
        }

        #captured-photo {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            filter: contrast(1.1) saturate(1.1) sepia(0.15);
            transition: opacity 0.2s ease-out;
        }

        .progress-text {
            margin-top: 25px;
            font-size: 1.8rem;
            color: #2c3e35;
        }

        .shake-hint {
            margin-top: 10px;
            font-size: 1rem;
            color: #d9534f;
            animation: blink 1s infinite;
        }

        /* --- 시퀀스 5: 결과 화면 버튼 --- */
        .result-actions {
            margin-top: 25px;
            display: none;
            gap: 15px;
        }

        .result-actions.show {
            display: flex;
        }

        button.action-btn {
            font-family: 'DungGeunMo', sans-serif;
            padding: 14px 22px;
            font-size: 1.1rem;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            color: white;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

        .btn-save { background-color: #4CAF50; }
        .btn-retake { background-color: #f0ad4e; }
        
        button.action-btn:active {
            transform: translateY(2px);
        }

        #canvas { display: none; }
    </style>
</head>
<body>

    <svg style="display: none;">
        <defs>
            <filter id="lens-distortion" x="-10%" y="-10%" width="120%" height="120%">
                <feTurbulence type="fractalNoise" baseFrequency="0.008" numOctaves="1" result="noise" />
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="18" xChannelSelector="R" yChannelSelector="G" />
            </filter>
        </defs>
    </svg>

    <!-- 시퀀스 1: 타이틀 화면 -->
    <div id="screen-title" class="screen active">
        <h1 class="title">폴라'노이드'</h1>
        
        <svg class="camera-svg-btn" id="start-btn" viewBox="0 0 200 220" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="10" width="180" height="200" rx="45" fill="#B4D6C1" stroke="#9bbfa9" stroke-width="3"/>
            <rect x="82" y="25" width="26" height="36" rx="6" fill="#e3e3e3" stroke="#bbb" stroke-width="2"/>
            <rect x="87" y="30" width="16" height="26" rx="3" fill="#ffffff"/>
            <rect x="26" y="32" width="24" height="24" rx="6" fill="#222222"/>
            <rect x="31" y="37" width="14" height="14" rx="3" fill="#ffffff" opacity="0.85"/>
            <circle cx="100" cy="130" r="58" fill="#a1c9b1" stroke="#8cb59c" stroke-width="3"/>
            <circle cx="100" cy="130" r="44" fill="#222222"/>
            <circle cx="100" cy="130" r="32" fill="#111111"/>
            <circle cx="92" cy="122" r="8" fill="#ffffff" opacity="0.35"/>
            <circle cx="38" cy="82" r="13" fill="#eeeeee" stroke="#cccccc" stroke-width="2"/>
            <text x="100" y="200" font-family="'DungGeunMo', sans-serif" font-size="11" fill="#587a65" text-anchor="middle">INSTAX MINI</text>
        </svg>

        <div class="instruction">카메라를 터치하여 시작하세요</div>
    </div>

    <!-- 시퀀스 2: 카메라 촬영 화면 -->
    <div id="screen-camera" class="screen">
        <video id="camera-stream" autoplay playsinline></video>
        <div class="viewfinder-overlay">
            <div class="viewfinder-cutout"></div>
        </div>
        <div class="shutter-btn" id="shutter-btn"></div>
    </div>

    <!-- 시퀀스 3, 4, 5: 사진 현상 및 결과 화면 -->
    <div id="screen-develop" class="screen">
        <div class="polaroid-frame" id="polaroid-frame">
            <div class="photo-area">
                <img id="captured-photo" src="" alt="현상된 사진">
            </div>
        </div>
        <div class="progress-text" id="progress-text">현상 중... 0%</div>
        <div class="shake-hint" id="shake-hint">📱 핸드폰을 흔들면 빨리 현상돼요!</div>
        
        <div class="result-actions" id="result-actions">
            <button class="action-btn btn-save" id="save-btn">저장하기</button>
            <button class="action-btn btn-retake" id="retake-btn">다시 촬영</button>
        </div>
    </div>

    <canvas id="canvas"></canvas>

    <script>
        const screenTitle = document.getElementById('screen-title');
        const screenCamera = document.getElementById('screen-camera');
        const screenDevelop = document.getElementById('screen-develop');
        const startBtn = document.getElementById('start-btn');
        const shutterBtn = document.getElementById('shutter-btn');
        const video = document.getElementById('camera-stream');
        const canvas = document.getElementById('canvas');
        const capturedPhoto = document.getElementById('captured-photo');
        const polaroidFrame = document.getElementById('polaroid-frame');
        const progressText = document.getElementById('progress-text');
        const shakeHint = document.getElementById('shake-hint');
        const resultActions = document.getElementById('result-actions');
        const saveBtn = document.getElementById('save-btn');
        const retakeBtn = document.getElementById('retake-btn');

        let stream;
        let developProgress = 0;
        let developInterval;
        let isDeveloping = false;
        
        let lastX = 0, lastY = 0, lastZ = 0;
        const shakeThreshold = 14;

        startBtn.addEventListener('click', async () => {
            try {
                if (typeof DeviceMotionEvent !== 'undefined' && typeof DeviceMotionEvent.requestPermission === 'function') {
                    const permission = await DeviceMotionEvent.requestPermission();
                    if (permission === 'granted') {
                        window.addEventListener('devicemotion', handleShake);
                    }
                } else {
                    window.addEventListener('devicemotion', handleShake);
                }

                stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'environment' },
                    audio: false
                });
                video.srcObject = stream;

                screenTitle.classList.remove('active');
                screenCamera.classList.add('active');

            } catch (err) {
                alert('카메라 및 센서 접근 권한이 필요합니다:\n' + err.message);
            }
        });

        shutterBtn.addEventListener('click', () => {
            canvas.width = 750;
            canvas.height = 1000;
            const ctx = canvas.getContext('2d');
            
            const vWidth = video.videoWidth;
            const vHeight = video.videoHeight;
            const minDim = Math.min(vWidth, vHeight);
            
            const sWidth = minDim;
            const sHeight = minDim * (1000/750);
            
            ctx.drawImage(video, 
                (vWidth - sWidth)/2, (vHeight - sHeight)/2, sWidth, sHeight, 
                0, 0, canvas.width, canvas.height
            );

            capturedPhoto.src = canvas.toDataURL('image/png');
            
            screenCamera.classList.remove('active');
            screenDevelop.classList.add('active');
            
            startDeveloping();
        });

        function startDeveloping() {
            isDeveloping = true;
            developProgress = 0;
            capturedPhoto.style.opacity = 0;
            polaroidFrame.classList.remove('slide-up');
            resultActions.classList.remove('show');
            shakeHint.style.display = 'block';
            progressText.innerText = `현상 중... 0%`;

            setTimeout(() => {
                polaroidFrame.classList.add('slide-up');
            }, 100);

            // 1분(60초) 기준: 100ms마다 타이머 작동 (총 600회)
            // 1회당 (100 / 600)% 씩 진행률 증가
            clearInterval(developInterval);
            developInterval = setInterval(() => {
                addProgress(100 / 600);
            }, 100);
        }

        function handleShake(event) {
            if (!isDeveloping) return;

            const acc = event.acceleration || event.accelerationIncludingGravity;
            if (!acc) return;

            const deltaX = Math.abs(acc.x - lastX);
            const deltaY = Math.abs(acc.y - lastY);
            const deltaZ = Math.abs(acc.z - lastZ);

            // 흔들림 감지 시 +1.5% 부스트 (1분 대기시간을 빠르게 단축)
            if (deltaX > shakeThreshold || deltaY > shakeThreshold || deltaZ > shakeThreshold) {
                addProgress(1.5);
            }

            lastX = acc.x;
            lastY = acc.y;
            lastZ = acc.z;
        }

        function addProgress(amount) {
            if (!isDeveloping) return;
            
            developProgress += amount;
            if (developProgress >= 100) developProgress = 100;

            progressText.innerText = `현상 중... ${Math.floor(developProgress)}%`;
            
            // 1% 이상부터 서서히 사진 투명도가 옅어지며 모습이 드러남
            if (developProgress > 0) {
                capturedPhoto.style.opacity = developProgress / 100;
            } else {
                capturedPhoto.style.opacity = 0;
            }

            if (developProgress >= 100) {
                completeDeveloping();
            }
        }

        function completeDeveloping() {
            isDeveloping = false;
            clearInterval(developInterval);
            progressText.innerText = "현상 완료!";
            shakeHint.style.display = 'none';
            resultActions.classList.add('show');
        }

        saveBtn.addEventListener('click', () => {
            const link = document.createElement('a');
            link.download = `polaroid_${Date.now()}.png`;
            link.href = capturedPhoto.src;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        });

        retakeBtn.addEventListener('click', () => {
            screenDevelop.classList.remove('active');
            screenCamera.classList.add('active');
            polaroidFrame.classList.remove('slide-up');
        });
    </script>
</body>
</html>
